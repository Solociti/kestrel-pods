{
  "name": "kestrel-pods",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.16.1",
  "scripts": {
    "build": "pnpm -r run build",
    "test": "pnpm -r run test",
    "typecheck": "pnpm -r run typecheck",
    "docker:build:dashboard": "docker build --network=host -f orchestrator/dashboard/Dockerfile -t kestrel-dashboard .",
    "docker:build:control-plane": "docker build --network=host -f control-plane/Dockerfile -t kestrel-control-plane .",
    "docker:build:router": "docker build --network=host -f router/Dockerfile -t kestrel-router .",
    "docker:build:vm-provision": "docker build --network=host -f orchestrator/vm-provision/Dockerfile -t kestrel-vm-provision .",
    "docker:build": "pnpm run docker:build:dashboard && pnpm run docker:build:control-plane && pnpm run docker:build:router && pnpm run docker:build:vm-provision"
  },
  "devDependencies": {
    "@kubernetes/client-node": "^1.4.0",
    "@types/node": "^24.13.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "js-yaml": "^5.2.1",
    "jsdom": "^29.1.1",
    "kubernetes-types": "^1.30.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tsup": "^8.5.1",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  }
}
